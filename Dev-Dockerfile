ARG FROM_IMAGE=netboxcommunity/netbox
ARG FROM_TAG=v4.3.7-3.3.0
ARG FROM=${FROM_IMAGE}:${FROM_TAG}
FROM ${FROM}

ENV VIRTUAL_ENV=/opt/netbox/venv
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

COPY ./adestis_netbox_applications /source/adestis-netbox-applications/adestis_netbox_applications/
COPY ./setup.py /source/adestis-netbox-applications/
COPY ./MANIFEST.in /source/adestis-netbox-applications/
COPY ./README.md /source/adestis-netbox-applications/
COPY ./docker/requirements-container.txt /source/adestis-netbox-applications/
COPY ./docker/configuration/configuration.py /etc/netbox/config/configuration.py
RUN /usr/local/bin/uv pip install /source/adestis-netbox-applications/
RUN /usr/local/bin/uv pip install -r /source/adestis-netbox-applications/requirements-container.txt